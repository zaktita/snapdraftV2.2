<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Canvas Editor - SnapDraft</title>
    <style>
        /* Notion/shadcn inspired design system */
        :root {
            --sidebar-width: 260px;
            --border-subtle: #e5e7eb;
            --bg-primary: #ffffff;
            --bg-secondary: #FAF9F7;
            --bg-tertiary: #fafafa;
            --text-primary: #37352f;
            --text-secondary: #787774;
            --text-tertiary: #9b9a97;
            --accent-primary: #373737;
            --accent-primary-hover: #1a1a1a;
            --accent-red: #eb5757;
            --accent-red-hover: #d84343;
            --shadow-subtle: 0 1px 2px rgba(0, 0, 0, 0.04);
            --shadow-medium: 0 2px 4px rgba(0, 0, 0, 0.06);
            --shadow-float: 0 4px 12px rgba(0, 0, 0, 0.08);
            --shadow-strong: 0 8px 24px rgba(0, 0, 0, 0.12);
            --transition: all 0.15s ease;
            --border-radius-sm: 4px;
            --border-radius-md: 6px;
            --border-radius-lg: 8px;
            --border-radius-xl: 12px;
            --sidebar-margin: 16px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
            background-color: var(--bg-secondary);
            overflow: hidden;
            color: var(--text-primary);
        }

        .app-container {
            height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Top Header */
        .top-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 20px;
            background: var(--bg-primary);
            border-bottom: 1px solid var(--border-subtle);
            z-index: 100;
            gap: 24px;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .header-center {
            display: flex;
            align-items: center;
            gap: 8px;
            flex: 0 0 auto;
        }

        .header-divider {
            width: 1px;
            height: 20px;
            background: var(--border-subtle);
            margin: 0 8px;
        }

        .back-btn {
            padding: 6px 10px;
            border: none;
            border-radius: var(--border-radius-md);
            background: transparent;
            cursor: pointer;
            font-size: 14px;
            color: var(--text-secondary);
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .back-btn:hover {
            background: var(--bg-secondary);
            color: var(--text-primary);
        }

        .editor-title {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .editor-title h1 {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-primary);
        }

        .header-right {
            display: flex;
            gap: 6px;
        }

        .header-btn {
            padding: 6px 12px;
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-md);
            background: transparent;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
            color: var(--text-secondary);
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .header-btn:hover {
            background: var(--bg-secondary);
            color: var(--text-primary);
        }

        .header-btn.primary {
            background: var(--accent-primary);
            color: white;
            border-color: var(--accent-primary);
        }

        .header-btn.primary:hover {
            background: var(--accent-primary-hover);
            border-color: var(--accent-primary-hover);
        }

        .header-btn.reset {
            color: var(--accent-red);
            border-color: transparent;
        }

        .header-btn.reset:hover {
            background: rgba(235, 87, 87, 0.1);
            color: var(--accent-red-hover);
        }

        /* Main Container */
        .main-container {
            flex: 1;
            display: flex;
            position: relative;
            overflow: hidden;
        }

        /* Sidebar */
        .editor-sidebar {
            position: absolute;
            left: var(--sidebar-margin);
            top: var(--sidebar-margin);
            width: var(--sidebar-width);
            background: var(--bg-primary);
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-xl);
            box-shadow: var(--shadow-float);
            display: flex;
            flex-direction: column;
            transition: var(--transition);
            z-index: 50;
        }

        .editor-sidebar.collapsed {
            width: 60px;
        }

        .editor-sidebar.collapsed .sidebar-header,
        .editor-sidebar.collapsed .section-label,
        .editor-sidebar.collapsed .tool-name,
        .editor-sidebar.collapsed .control-label,
        .editor-sidebar.collapsed .control-slider,
        .editor-sidebar.collapsed .tips-section {
            display: none;
        }

        .editor-sidebar.collapsed .tool-card {
            justify-content: center;
            padding: 10px;
        }

        .sidebar-header {
            padding: 20px 16px 16px;
            border-bottom: 1px solid var(--border-subtle);
        }

        .sidebar-title {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 0;
            letter-spacing: 0;
            text-transform: none;
        }

        .sidebar-subtitle {
            font-size: 11px;
            color: var(--text-tertiary);
            margin-top: 4px;
        }

        .sidebar-content {
            overflow-y: auto;
            padding: 16px;
        }

        /* Scrollbar styling for sidebar */
        .sidebar-content::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar-content::-webkit-scrollbar-track {
            background: transparent;
        }

        .sidebar-content::-webkit-scrollbar-thumb {
            background: var(--border-subtle);
            border-radius: 3px;
        }

        .sidebar-content::-webkit-scrollbar-thumb:hover {
            background: var(--text-tertiary);
        }

        .tool-section {
            margin-bottom: 24px;
        }

        .section-label {
            font-size: 11px;
            font-weight: 600;
            color: var(--text-tertiary);
            text-transform: none;
            letter-spacing: 0;
            margin-bottom: 6px;
            padding: 0 4px;
        }

        .tool-grid {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .tool-card {
            padding: 8px 12px;
            border: none;
            border-radius: var(--border-radius-sm);
            background: transparent;
            cursor: pointer;
            transition: var(--transition);
            text-align: left;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .tool-card:hover {
            background: var(--bg-secondary);
        }

        .tool-card.active {
            background: var(--bg-secondary);
            color: var(--text-primary);
        }

        .tool-icon {
            font-size: 18px;
            width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            color: var(--text-secondary);
        }

        .tool-icon svg {
            stroke: var(--text-secondary);
        }

        .tool-card:hover .tool-icon svg {
            stroke: var(--text-primary);
        }

        .tool-card.active .tool-icon svg {
            stroke: var(--text-primary);
        }

        .tool-name {
            font-size: 14px;
            font-weight: 400;
            color: var(--text-primary);
        }

        .tool-card.active .tool-name {
            font-weight: 500;
        }

        /* Brush Controls */
        .brush-controls {
            background: transparent;
            border-radius: 0;
            padding: 0;
            margin-top: 0;
        }

        .control-group {
            margin-bottom: 20px;
        }

        .control-group:last-child {
            margin-bottom: 0;
        }

        .control-label {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 14px;
            font-weight: 400;
            color: var(--text-primary);
            margin-bottom: 10px;
        }

        .control-value {
            font-size: 13px;
            color: var(--text-tertiary);
            font-weight: 500;
        }

        .control-slider {
            width: 100%;
            height: 2px;
            border-radius: 2px;
            background: var(--border-subtle);
            outline: none;
            -webkit-appearance: none;
            appearance: none;
        }

        .control-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            appearance: none;
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: var(--text-primary);
            cursor: pointer;
            transition: var(--transition);
        }

        .control-slider::-webkit-slider-thumb:hover {
            background: var(--accent-primary);
            transform: scale(1.1);
        }

        .control-slider::-moz-range-thumb {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: var(--text-primary);
            cursor: pointer;
            border: none;
            transition: var(--transition);
        }

        .control-slider::-moz-range-thumb:hover {
            background: var(--accent-primary);
            transform: scale(1.1);
        }

        .control-hint {
            font-size: 11px;
            color: var(--text-tertiary);
            margin-top: 6px;
        }

        /* Tips Section */
        .tips-section {
            background: var(--bg-secondary);
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-md);
            padding: 12px 14px;
        }

        .tips-title {
            font-size: 14px;
            font-weight: 500;
            color: var(--text-primary);
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .tips-title svg {
            stroke: var(--text-secondary);
            flex-shrink: 0;
        }

        .tip-item {
            font-size: 13px;
            color: var(--text-secondary);
            margin-bottom: 6px;
            line-height: 1.6;
            padding-left: 16px;
            position: relative;
        }

        .tip-item:before {
            content: "•";
            position: absolute;
            left: 4px;
            color: var(--text-tertiary);
            font-weight: 600;
        }

        .tip-item:last-child {
            margin-bottom: 0;
        }

        /* Canvas Container */
        .canvas-wrapper {
            flex: 1;
            position: relative;
            overflow: hidden;
            background: var(--bg-secondary);
        }

        .canvas-container {
            width: 100%;
            height: 100%;
            position: relative;
            overflow: hidden;
        }

        .main-canvas {
            display: block;
            cursor: default;
        }

        /* Upload Zone */
        .upload-zone {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 480px;
            max-width: 90%;
            padding: 60px 40px;
            background: var(--bg-primary);
            border: 2px dashed var(--border-subtle);
            border-radius: 12px;
            cursor: pointer;
            transition: var(--transition);
            text-align: center;
        }

        .upload-zone:hover {
            border-color: var(--accent-purple);
            background: var(--bg-secondary);
            box-shadow: var(--shadow-medium);
        }

        .upload-icon {
            font-size: 48px;
            margin-bottom: 16px;
            opacity: 0.8;
        }

        .upload-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 8px;
        }

        .upload-subtitle {
            font-size: 14px;
            color: var(--text-secondary);
        }

        .upload-subtitle span {
            color: var(--accent-purple);
            text-decoration: underline;
        }

        .file-input {
            display: none;
        }

        /* View Controls */
        .view-controls {
            position: absolute;
            top: 16px;
            left: 16px;
            background: var(--bg-primary);
            padding: 6px 10px;
            border-radius: var(--border-radius-md);
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 13px;
            color: var(--text-secondary);
            box-shadow: var(--shadow-subtle);
            border: 1px solid var(--border-subtle);
        }

        .view-control-btn {
            padding: 4px 8px;
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-sm);
            background: transparent;
            cursor: pointer;
            font-size: 12px;
            font-weight: 500;
            color: var(--text-secondary);
            transition: var(--transition);
        }

        .view-control-btn:hover {
            background: var(--bg-secondary);
            color: var(--text-primary);
        }

        /* Floating Actions */
        .floating-actions {
            position: absolute;
            bottom: 24px;
            right: 24px;
            background: var(--bg-primary);
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-lg);
            padding: 4px;
            box-shadow: var(--shadow-medium);
            display: flex;
            flex-direction: column;
            gap: 2px;
            min-width: 200px;
        }

        .floating-btn {
            padding: 10px 14px;
            background: transparent;
            color: var(--text-primary);
            border: none;
            border-radius: var(--border-radius-sm);
            cursor: pointer;
            font-weight: 400;
            font-size: 14px;
            transition: var(--transition);
            display: flex;
            align-items: center;
            gap: 10px;
            text-align: left;
        }

        .floating-btn:hover {
            background: var(--bg-secondary);
        }

        .floating-btn svg {
            width: 16px;
            height: 16px;
            flex-shrink: 0;
            stroke: var(--text-secondary);
        }

        .floating-btn:hover svg {
            stroke: var(--text-primary);
        }

        /* Primary action button */
        .floating-btn:last-child {
            font-weight: 500;
        }

        .floating-btn:last-child:hover {
            background: var(--accent-primary);
            color: white;
        }

        .floating-btn:last-child:hover svg {
            stroke: white;
        }

        /* Reset Button */
        .reset-btn {
            position: absolute;
            top: 16px;
            right: 16px;
            padding: 6px 12px;
            background: var(--bg-primary);
            color: var(--accent-red);
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-md);
            cursor: pointer;
            font-size: 13px;
            font-weight: 500;
            box-shadow: var(--shadow-subtle);
            transition: var(--transition);
        }

        .reset-btn:hover {
            background: rgba(235, 87, 87, 0.1);
            border-color: var(--accent-red);
            color: var(--accent-red-hover);
        }

        /* Object Toolbar */
        .object-toolbar {
            position: absolute;
            background: var(--bg-primary);
            padding: 4px;
            border-radius: var(--border-radius-lg);
            display: flex;
            gap: 2px;
            box-shadow: var(--shadow-medium);
            border: 1px solid var(--border-subtle);
            z-index: 1000;
        }

        .object-toolbar button {
            padding: 8px;
            background: transparent;
            border: none;
            border-radius: var(--border-radius-sm);
            cursor: pointer;
            font-size: 14px;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-secondary);
        }

        .object-toolbar button:hover {
            background: var(--bg-secondary);
            color: var(--text-primary);
        }

        /* Zoom Controls (in header) */
        .zoom-controls {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .zoom-btn {
            width: 28px;
            height: 28px;
            border: none;
            border-radius: var(--border-radius-sm);
            background: transparent;
            cursor: pointer;
            font-size: 16px;
            font-weight: 400;
            color: var(--text-secondary);
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .zoom-btn:hover {
            background: var(--bg-secondary);
            color: var(--text-primary);
        }

        .zoom-display {
            font-size: 13px;
            font-weight: 400;
            color: var(--text-secondary);
            min-width: 50px;
            text-align: center;
            cursor: pointer;
            padding: 4px 8px;
            border-radius: var(--border-radius-sm);
            transition: var(--transition);
        }

        .zoom-display:hover {
            background: var(--bg-secondary);
        }

        /* Sidebar Toggle Button */
        .sidebar-toggle {
            position: absolute;
            left: calc(var(--sidebar-width) + var(--sidebar-margin));
            top: calc(var(--sidebar-margin) + 20px);
            width: 28px;
            height: 28px;
            background: var(--bg-primary);
            border: 1px solid var(--border-subtle);
            border-radius: var(--border-radius-md);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: var(--transition);
            z-index: 60;
            box-shadow: var(--shadow-subtle);
        }

        .sidebar-toggle:hover {
            background: var(--bg-secondary);
            box-shadow: var(--shadow-medium);
        }

        .editor-sidebar.collapsed ~ .sidebar-toggle {
            left: calc(60px + var(--sidebar-margin));
        }

        .sidebar-toggle svg {
            transition: var(--transition);
            width: 16px;
            height: 16px;
        }

        .editor-sidebar.collapsed ~ .sidebar-toggle svg {
            transform: rotate(180deg);
        }

        /* Custom Prompt Modal */
        .prompt-modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            opacity: 0;
            animation: fadeIn 0.2s ease forwards;
        }

        @keyframes fadeIn {
            to {
                opacity: 1;
            }
        }

        @keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: scale(0.95) translateY(10px);
            }
            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        .prompt-modal-container {
            background: #ffffff;
            border: 1px solid #ebebeb;
            border-radius: 12px;
            padding: 24px;
            width: 90%;
            max-width: 520px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
            animation: modalSlideIn 0.3s ease forwards;
        }

        .prompt-modal-header {
            margin-bottom: 20px;
        }

        .prompt-modal-title-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 8px;
        }

        .prompt-modal-icon {
            font-size: 24px;
            line-height: 1;
            color: #373737;
        }

        .prompt-modal-icon svg {
            width: 24px;
            height: 24px;
            stroke: #373737;
        }

        .prompt-modal-title {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
            font-size: 18px;
            font-weight: 600;
            color: #373737;
            margin: 0;
        }

        .prompt-modal-description {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
            font-size: 14px;
            font-weight: 400;
            color: #8a8a8a;
            margin: 0;
            line-height: 1.5;
        }

        .prompt-modal-body {
            margin-bottom: 20px;
        }

        .prompt-modal-textarea {
            width: 100%;
            min-height: 120px;
            padding: 12px;
            background: #f7f7f7;
            border: 1px solid #ebebeb;
            border-radius: 6px;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
            font-size: 14px;
            color: #373737;
            resize: vertical;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
            outline: none;
        }

        .prompt-modal-textarea::placeholder {
            color: #8a8a8a;
        }

        .prompt-modal-textarea:focus {
            border: 1.5px solid #1a1a1a;
            box-shadow: 0 0 0 3px rgba(26, 26, 26, 0.05);
        }

        .prompt-modal-footer {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
        }

        .prompt-modal-btn {
            padding: 10px 20px;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
            font-size: 14px;
            font-weight: 500;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s ease;
            border: none;
            outline: none;
        }

        .prompt-modal-btn-cancel {
            background: transparent;
            border: 1px solid #ebebeb;
            color: #373737;
        }

        .prompt-modal-btn-cancel:hover {
            background: #f7f7f7;
        }

        .prompt-modal-btn-primary {
            background: #1a1a1a;
            color: #ffffff;
            border: 1px solid #1a1a1a;
        }

        .prompt-modal-btn-primary:hover {
            background: #000000;
            border-color: #000000;
        }

        .prompt-modal-btn-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .prompt-modal-btn-danger {
            background: #dc2626;
            color: #ffffff;
            border: 1px solid #dc2626;
        }

        .prompt-modal-btn-danger:hover {
            background: #b91c1c;
            border-color: #b91c1c;
        }

        /* Responsive */
        @media (max-width: 768px) {
            :root {
                --sidebar-margin: 8px;
                --sidebar-width: 240px;
            }

            .editor-sidebar {
                left: var(--sidebar-margin);
                top: var(--sidebar-margin);
                bottom: var(--sidebar-margin);
            }

            .sidebar-toggle {
                display: none;
            }

            .header-center {
                display: none;
            }

            .header-right {
                gap: 4px;
            }

            .header-btn span {
                display: none;
            }
        }

        /* Utility */
        .hidden {
            display: none !important;
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- Top Header -->
        <div class="top-header">
            <div class="header-left">
                <button class="back-btn" onclick="closeEditor()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 12H5M12 19l-7-7 7-7"/>
                    </svg>
                    <span>Back</span>
                </button>
                <div class="editor-title">
                    <h1>Canvas Editor</h1>
                </div>
            </div>
            <div class="header-center">
                <div class="zoom-controls">
                    <button class="zoom-btn" onclick="zoomOut()" title="Zoom Out">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                    </button>
                    <div class="zoom-display" id="headerZoomDisplay" onclick="resetZoom()" title="Click to reset zoom">100%</div>
                    <button class="zoom-btn" onclick="zoomIn()" title="Zoom In">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="5" x2="12" y2="19"/>
                            <line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                    </button>
                </div>
                <div class="header-divider"></div>
                <button class="header-btn" onclick="fitToScreen()" title="Fit canvas to screen">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/>
                    </svg>
                    <span>Fit</span>
                </button>
            </div>
            <div class="header-right">
                <button class="header-btn" onclick="undo()" title="Undo (Ctrl+Z)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 7v6h6"/>
                        <path d="M21 17a9 9 0 00-9-9 9 9 0 00-6 2.3L3 13"/>
                    </svg>
                </button>
                <button class="header-btn" onclick="redo()" title="Redo (Ctrl+Shift+Z)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 7v6h-6"/>
                        <path d="M3 17a9 9 0 019-9 9 9 0 016 2.3l3 2.7"/>
                    </svg>
                </button>
                <button class="header-btn" onclick="resetDrawing()" title="Clear all brush strokes">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                    </svg>
                </button>
                <div class="header-divider"></div>
                <button class="header-btn" onclick="applyChanges()" title="Apply changes to selected image">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                    <span>Apply</span>
                </button>
                <button class="header-btn primary" onclick="downloadImage()">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                        <polyline points="7 10 12 15 17 10"/>
                        <line x1="12" y1="15" x2="12" y2="3"/>
                    </svg>
                    <span>Download</span>
                </button>
            </div>
        </div>

        <!-- Main Container -->
        <div class="main-container">
            <!-- Sidebar -->
            <div class="editor-sidebar" id="editorSidebar">
                <div class="sidebar-header">
                    <div class="sidebar-title">Canvas editor</div>
                    <div class="sidebar-subtitle">Select a tool to get started</div>
                </div>

                <div class="sidebar-content">
                    <!-- Tools Section -->
                    <div class="tool-section">
                        <div class="section-label">Editing tools</div>
                        <div class="tool-grid">
                            <div class="tool-card active" data-tool="select" onclick="selectTool('select')">
                                <div class="tool-icon">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"/>
                                    </svg>
                                </div>
                                <div class="tool-name">Select</div>
                            </div>
                            <div class="tool-card" data-tool="retouch" onclick="selectTool('retouch')">
                                <div class="tool-icon">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M12 19l7-7 3 3-7 7-3-3z"/>
                                        <path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/>
                                        <path d="M2 2l7.586 7.586"/>
                                    </svg>
                                </div>
                                <div class="tool-name">Retouch</div>
                            </div>
                            <div class="tool-card" data-tool="background" onclick="selectTool('background')">
                                <div class="tool-icon">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <rect x="3" y="3" width="18" height="18" rx="2"/>
                                        <circle cx="8.5" cy="8.5" r="1.5"/>
                                        <path d="M21 15l-5-5L5 21"/>
                                    </svg>
                                </div>
                                <div class="tool-name">Background</div>
                            </div>
                            <div class="tool-card" data-tool="expand" onclick="selectTool('expand')">
                                <div class="tool-icon">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <path d="M21 21l-6-6m6 6v-4.8m0 4.8h-4.8"/>
                                        <path d="M3 16.2V21m0 0h4.8M3 21l6-6"/>
                                        <path d="M21 7.8V3m0 0h-4.8M21 3l-6 6"/>
                                        <path d="M3 7.8V3m0 0h4.8M3 3l6 6"/>
                                    </svg>
                                </div>
                                <div class="tool-name">Expand</div>
                            </div>
                            <div class="tool-card" data-tool="upscale" onclick="selectTool('upscale')">
                                <div class="tool-icon">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="17 11 12 6 7 11"/>
                                        <polyline points="17 18 12 13 7 18"/>
                                    </svg>
                                </div>
                                <div class="tool-name">Upscale</div>
                            </div>
                        </div>
                    </div>

                    <!-- Brush Controls -->
                    <div class="tool-section">
                        <div class="section-label">Brush settings</div>
                        <div class="brush-controls">
                            <div class="control-group">
                                <div class="control-label">
                                    <span>Brush size</span>
                                    <span class="control-value" id="brushSizeValue">20px</span>
                                </div>
                                <input type="range" class="control-slider" id="brushSize" min="5" max="100" value="20" oninput="updateBrushSize(this.value)">
                            </div>
                            <div class="control-group">
                                <div class="control-label">
                                    <span>Brush opacity</span>
                                    <span class="control-value" id="brushOpacityValue">100%</span>
                                </div>
                                <input type="range" class="control-slider" id="brushOpacity" min="10" max="100" value="100" oninput="updateBrushOpacity(this.value)">
                            </div>
                        </div>
                    </div>

                    <!-- Tips Section -->
                    <div class="tool-section">
                        <div class="tips-section">
                            <div class="tips-title">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="10"/>
                                    <path d="M12 16v-4"/>
                                    <path d="M12 8h.01"/>
                                </svg>
                                <span>Navigation tips</span>
                            </div>
                            <div class="tip-item">Pan canvas with Space + Drag or Middle Mouse Button</div>
                            <div class="tip-item">Zoom with Mouse Wheel</div>
                            <div class="tip-item">Reset view with Ctrl+0</div>
                            <div class="tip-item">Undo with Ctrl+Z, Redo with Ctrl+Shift+Z</div>
                            <div class="tip-item">Press V, R, B, E, or U to switch tools</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar Toggle -->
            <button class="sidebar-toggle" onclick="toggleSidebar()">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M15 18l-6-6 6-6"/>
                </svg>
            </button>

            <!-- Canvas Wrapper -->
            <div class="canvas-wrapper">
                <div class="canvas-container" id="canvasContainer">
                    <!-- Upload Zone -->
                    <div class="upload-zone" id="uploadZone" onclick="document.getElementById('fileInput').click()">
                        <div class="upload-icon">🖼️</div>
                        <div class="upload-title">Upload an Image</div>
                        <div class="upload-subtitle">
                            Drop your image here or <span>click to browse</span>
                        </div>
                        <input type="file" class="file-input" id="fileInput" accept="image/*" onchange="handleFileUpload(event)">
                    </div>

                    <!-- Canvas will be inserted here -->
                    <canvas id="mainCanvas" class="main-canvas hidden"></canvas>

                

                    <!-- Floating Actions -->
                    <div class="floating-actions hidden" id="floatingActions">
                        <button class="floating-btn" onclick="handleErase()" title="Remove content in masked area">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M16 6L4 18m0-12l12 12"/>
                            </svg>
                            Erase Masked Area
                        </button>
                        <button class="floating-btn" onclick="handleReplaceText()" title="Replace masked area with text">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="4 7 4 4 20 4 20 7"/>
                                <line x1="9" y1="20" x2="15" y2="20"/>
                                <line x1="12" y1="4" x2="12" y2="20"/>
                            </svg>
                            Replace with Text
                        </button>
                        <button class="floating-btn" onclick="handleGenerate()" title="Generate AI content in masked area">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                            </svg>
                            AI Generate
                        </button>
                        <button class="floating-btn" onclick="downloadMask()" title="Download mask as PNG">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                                <polyline points="7 10 12 15 17 10"/>
                                <line x1="12" y1="15" x2="12" y2="3"/>
                            </svg>
                            Download Mask
                        </button>
                    </div>

                    <!-- Object Toolbar -->
                    <div class="object-toolbar hidden" id="objectToolbar">
                        <button onclick="duplicateSelectedObject()" title="Duplicate">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                            </svg>
                        </button>
                        <button onclick="bringToFront()" title="Bring to Front">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 5l0 14M5 12l7-7 7 7"/>
                            </svg>
                        </button>
                        <button onclick="sendToBack()" title="Send to Back">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 19l0-14M5 12l7 7 7-7"/>
                            </svg>
                        </button>
                        <button onclick="deleteSelectedObject()" title="Delete">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <polyline points="3 6 5 6 21 6"/>
                                <path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
        // Global state
        let canvas, ctx;
        let image = null;
        let currentTool = 'select'; // Default to Select
        let brushSize = 50;
        let isPainting = false;
        let isDragging = false;
        let lines = [];
        let scale = 1;
        let panX = 0;
        let panY = 0;
        let lastPanPoint = { x: 0, y: 0 };
        let undoStack = [];
        let redoStack = [];
        let canvasObjects = [];
        let selectedObject = null;
        let draggedObject = null;
        let dragOffset = { x: 0, y: 0 };
        let isLoading = false;

        document.addEventListener('DOMContentLoaded', function() {
            canvas = document.getElementById('mainCanvas');
            ctx = canvas.getContext('2d');
            resizeCanvas();
            window.addEventListener('resize', () => {
                clearTimeout(window.resizeTimer);
                window.resizeTimer = setTimeout(resizeCanvas, 100);
            });
            setupDragAndDrop();
            setupCanvasEvents();
            setupKeyboardShortcuts();
            const urlParams = new URLSearchParams(window.location.search);
            const imageUrl = urlParams.get('image');
            if (imageUrl) {
                loadImageFromUrl(decodeURIComponent(imageUrl));
                if (urlParams.get('title')) document.title = `Editing: ${decodeURIComponent(urlParams.get('title'))} - Canvas Editor`;
            }
        });

        // ... (rest of helper functions remain unchanged until displayGeneratedResult)

        // Coordinate helpers
        function screenToCanvasCoordinates(screenX, screenY) {
            return { x: (screenX - panX) / scale, y: (screenY - panY) / scale };
        }
        function objectToScreenCoordinates(objX, objY) {
            return { x: objX * scale + panX, y: objY * scale + panY };
        }
        function screenToObjectCoordinates(screenX, screenY, obj) {
            const canvasPos = screenToCanvasCoordinates(screenX, screenY);
            return { x: canvasPos.x - obj.x, y: canvasPos.y - obj.y };
        }
        function isPointInObject(x, y, obj) {
            return x >= 0 && x <= obj.image.width && y >= 0 && y <= obj.image.height;
        }
        function getObjectAtPoint(screenX, screenY) {
            for (let i = canvasObjects.length - 1; i >= 0; i--) {
                const obj = canvasObjects[i];
                const objPos = screenToObjectCoordinates(screenX, screenY, obj);
                if (isPointInObject(objPos.x, objPos.y, obj)) return obj;
            }
            return null;
        }
        function updateHoverCursor(x, y) {
            if (isDragging || draggedObject) return;
            const hoveredObject = getObjectAtPoint(x, y);
            if (hoveredObject) {
                if (currentTool === 'retouch' && hoveredObject === selectedObject) {
                    updateCursor();
                } else {
                    canvas.style.cursor = 'grab';
                }
            } else {
                canvas.style.cursor = 'default';
            }
        }

        // Tool functions
        function selectTool(toolName) {
            currentTool = toolName;
            
            // Update UI - use new class names
            document.querySelectorAll('.tool-card').forEach(item => item.classList.remove('active'));
            document.querySelector(`[data-tool="${toolName}"]`).classList.add('active');

            const floatingActions = document.getElementById('floatingActions');

            // Show/hide floating actions based on tool
            if (toolName === 'retouch') {
                floatingActions.classList.remove('hidden');
            } else {
                floatingActions.classList.add('hidden');
            }
            
            updateCursor();
        }

        function updateBrushSize(value) {
            brushSize = parseInt(value);
            document.getElementById('brushSizeValue').textContent = brushSize + 'px';
            updateCursor();
        }

        function updateBrushOpacity(value) {
            brushOpacity = parseInt(value) / 100;
            document.getElementById('brushOpacityValue').textContent = value + '%';
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('editorSidebar');
            sidebar.classList.toggle('collapsed');
        }

        function updateCursor() {
            if (isDragging || draggedObject) {
                canvas.style.cursor = 'grabbing';
            } else if (currentTool === 'retouch' && selectedObject) {
                const scaledBrushSize = brushSize * scale;
                const cursorSize = Math.max(20, scaledBrushSize);
                const cursorSvg = `
                    <svg xmlns="http://www.w3.org/2000/svg" width="${cursorSize}" height="${cursorSize}" viewBox="0 0 ${cursorSize} ${cursorSize}">
                        <circle cx="${cursorSize / 2}" cy="${cursorSize / 2}" r="${scaledBrushSize / 2}" fill="none" stroke="#4CAF50" stroke-width="2" opacity="0.7"/>
                        <circle cx="${cursorSize / 2}" cy="${cursorSize / 2}" r="2" fill="#4CAF50"/>
                    </svg>
                `;
                const encoded = encodeURIComponent(cursorSvg);
                canvas.style.cursor = `url('data:image/svg+xml;charset=utf8,${encoded}') ${cursorSize / 2} ${cursorSize / 2}, crosshair`;
            } else {
                canvas.style.cursor = 'default'; // Standard arrow for Select and other tools
            }
        }

        // Mouse event handlers
        function handleMouseDown(e) {
            const rect = canvas.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            if (e.button === 1 || e.ctrlKey) {
                isDragging = true;
                lastPanPoint = { x: e.clientX, y: e.clientY };
                canvas.style.cursor = 'grabbing';
                return;
            }
            const clickedObject = getObjectAtPoint(x, y);
            if (clickedObject) {
                selectedObject = clickedObject;
                // Only start painting if in 'retouch' mode AND clicking the selected object
                if (currentTool === 'retouch' && clickedObject === selectedObject) {
                    const imagePos = screenToObjectCoordinates(x, y, clickedObject);
                    if (isPointInObject(imagePos.x, imagePos.y, clickedObject)) {
                        isPainting = true;
                        startNewLine(imagePos.x, imagePos.y);
                        saveState();
                    }
                } else {
                    // In 'select' mode or clicking a different object → just drag/select
                    draggedObject = clickedObject;
                    const objScreenPos = objectToScreenCoordinates(clickedObject.x, clickedObject.y);
                    dragOffset.x = x - objScreenPos.x;
                    dragOffset.y = y - objScreenPos.y;
                    canvas.style.cursor = 'grabbing';
                }
                drawScene();
            } else {
                selectedObject = null;
                drawScene();
            }
        }

        function handleMouseMove(e) {
            const rect = canvas.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            if (isDragging) {
                const dx = e.clientX - lastPanPoint.x;
                const dy = e.clientY - lastPanPoint.y;
                panX += dx;
                panY += dy;
                lastPanPoint = { x: e.clientX, y: e.clientY };
                drawScene();
                return;
            }
            if (draggedObject) {
                const newPos = screenToCanvasCoordinates(x - dragOffset.x, y - dragOffset.y);
                draggedObject.x = newPos.x;
                draggedObject.y = newPos.y;
                drawScene();
                return;
            }
            if (isPainting && currentTool === 'retouch' && selectedObject) {
                const imagePos = screenToObjectCoordinates(x, y, selectedObject);
                if (isPointInObject(imagePos.x, imagePos.y, selectedObject)) {
                    addPointToCurrentLine(imagePos.x, imagePos.y);
                    drawScene();
                } else {
                    isPainting = false;
                }
            }
            updateHoverCursor(x, y);
        }

        function handleMouseUp(e) {
            if (isDragging) {
                isDragging = false;
                updateCursor();
            }
            if (draggedObject) {
                draggedObject = null;
                updateCursor();
            }
            if (isPainting) {
                isPainting = false;
                updateStrokeCount();
            }
        }

        // ... (other functions like zoom, undo, etc. remain unchanged)

        // Key fix: spawn 20px right
        async function displayGeneratedResult(generatedImageUrl) {
            return new Promise((resolve, reject) => {
                const generatedImg = new Image();
                generatedImg.crossOrigin = 'anonymous';
                generatedImg.onload = () => {
                    const sourceObject = selectedObject;
                    if (sourceObject) {
                        const generatedObj = {
                            id: 'generated-' + Date.now(),
                            image: generatedImg,
                            x: sourceObject.x + sourceObject.image.width + 20, // ← 20px gap
                            y: sourceObject.y,
                            isMainImage: false,
                            label: `${sourceObject.label} (Edited)`
                        };
                        canvasObjects.push(generatedObj);
                        selectedObject = generatedObj;
                        isLoading = false;
                        drawScene();
                        showTemporaryMessage('✨ Generated image added to canvas', '#4CAF50');
                    }
                    resolve();
                };
                generatedImg.onerror = () => {
                    isLoading = false;
                    reject(new Error('Failed to load generated image'));
                };
                generatedImg.src = generatedImageUrl;
            });
        }

        // ... (rest of the script remains as in your original, including downloadImage, etc.)
        
        // Utility functions (keep your existing ones)
        function resizeCanvas() {
            const container = document.getElementById('canvasContainer');
            if (!container || container.style.display === 'none') return;
            canvas.width = container.clientWidth;
            canvas.height = container.clientHeight;
            if (image) drawScene();
        }

        function setupDragAndDrop() {
            const uploadZone = document.getElementById('uploadZone');
            ['dragover', 'dragenter'].forEach(evt => {
                uploadZone.addEventListener(evt, (e) => {
                    e.preventDefault();
                    uploadZone.style.borderColor = '#4CAF50';
                    uploadZone.style.background = 'rgba(76, 175, 80, 0.1)';
                });
            });
            ['dragleave', 'dragend'].forEach(evt => {
                uploadZone.addEventListener(evt, (e) => {
                    uploadZone.style.borderColor = '#dee2e6';
                    uploadZone.style.background = '#f8f9fa';
                });
            });
            uploadZone.addEventListener('drop', (e) => {
                e.preventDefault();
                uploadZone.style.borderColor = '#dee2e6';
                uploadZone.style.background = '#f8f9fa';
                const files = e.dataTransfer.files;
                if (files.length > 0) loadImageFile(files[0]);
            });
        }

        function setupCanvasEvents() {
            canvas.addEventListener('mousedown', handleMouseDown);
            canvas.addEventListener('mousemove', handleMouseMove);
            canvas.addEventListener('mouseup', handleMouseUp);
            canvas.addEventListener('wheel', handleWheel);
            canvas.addEventListener('contextmenu', (e) => e.preventDefault());
            canvas.addEventListener('touchstart', handleTouchStart);
            canvas.addEventListener('touchmove', handleTouchMove);
            canvas.addEventListener('touchend', handleTouchEnd);
        }

        function setupKeyboardShortcuts() {
            console.log('=== Keyboard shortcuts initialized ===');
            document.addEventListener('keydown', (e) => {
                // Debug: Log all keydown events
                console.log('Key pressed:', {
                    code: e.code,
                    key: e.key,
                    ctrlKey: e.ctrlKey,
                    metaKey: e.metaKey,
                    shiftKey: e.shiftKey,
                    target: e.target.tagName
                });

                // Prevent shortcuts when typing in inputs/textareas
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') {
                    console.log('Ignoring shortcut - typing in input/textarea');
                    return;
                }

                // Space for pan
                if (e.code === 'Space' && !e.repeat) {
                    e.preventDefault();
                    canvas.style.cursor = 'grab';
                }
                
                // Ctrl+0: Reset view
                if ((e.ctrlKey || e.metaKey) && e.code === 'Digit0') {
                    e.preventDefault();
                    console.log('Reset view triggered');
                    resetView();
                }
                
                // Ctrl+Z: Undo, Ctrl+Shift+Z: Redo (check both code and key for keyboard layout compatibility)
                if ((e.ctrlKey || e.metaKey) && (e.code === 'KeyZ' || e.key === 'z' || e.key === 'Z') && !e.shiftKey) {
                    e.preventDefault();
                    console.log('Ctrl+Z detected - calling undo()');
                    undo();
                }
                if ((e.ctrlKey || e.metaKey) && e.shiftKey && (e.code === 'KeyZ' || e.key === 'z' || e.key === 'Z')) {
                    e.preventDefault();
                    console.log('Ctrl+Shift+Z detected - calling redo()');
                    redo();
                }
                
                // Tool shortcuts
                if (e.code === 'KeyV') {
                    e.preventDefault();
                    selectTool('select');
                }
                if (e.code === 'KeyR') {
                    e.preventDefault();
                    selectTool('retouch');
                }
                if (e.code === 'KeyB') {
                    e.preventDefault();
                    selectTool('background');
                }
                if (e.code === 'KeyE') {
                    e.preventDefault();
                    selectTool('expand');
                }
                if (e.code === 'KeyU') {
                    e.preventDefault();
                    selectTool('upscale');
                }
                
                // Delete object
                if (e.code === 'Delete' && selectedObject && !selectedObject.isMainImage) {
                    e.preventDefault();
                    deleteSelectedObject();
                }
                
                // Ctrl+D: Duplicate
                if ((e.ctrlKey || e.metaKey) && e.code === 'KeyD') {
                    e.preventDefault();
                    duplicateSelectedObject();
                }
                
                // Layer management
                if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.code === 'BracketRight') {
                    e.preventDefault();
                    bringToFront();
                }
                if ((e.ctrlKey || e.metaKey) && e.shiftKey && e.code === 'BracketLeft') {
                    e.preventDefault();
                    sendToBack();
                }
            });
            document.addEventListener('keyup', (e) => {
                if (e.code === 'Space') updateCursor();
            });
        }

        function handleFileUpload(event) {
            const file = event.target.files[0];
            if (file) loadImageFile(file);
        }

        function handleTestFileUpload(event) {
            const file = event.target.files[0];
            if (file) {
                const statusElement = document.getElementById('testUploadStatus');
                statusElement.textContent = '⏳ Loading...';
                statusElement.style.color = '#FF9800';
                loadImageFile(file);
                setTimeout(() => {
                    showTemporaryMessage('✅ Test image loaded successfully', '#4CAF50');
                    statusElement.textContent = '✅ Ready for testing';
                    statusElement.style.color = '#4CAF50';
                    setTimeout(() => { statusElement.textContent = ''; }, 3000);
                }, 200);
                lines = [];
                updateStrokeCount();
                setTimeout(() => fitToScreen(), 300);
            }
            event.target.value = '';
        }

        function loadImageFile(file) {
            if (!file.type.startsWith('image/')) {
                showCustomAlert('Invalid File', 'Please select an image file.', 'warning');
                return;
            }
            const reader = new FileReader();
            reader.onload = (e) => loadImageFromUrl(e.target.result);
            reader.readAsDataURL(file);
        }

        function loadImageFromUrl(src) {
            const img = new Image();
            img.onload = () => {
                image = img;
                const mainImageObj = {
                    id: 'main-image',
                    image: img,
                    x: 0,
                    y: 0,
                    isMainImage: true,
                    label: 'Original'
                };
                canvasObjects = [mainImageObj];
                selectedObject = mainImageObj;
                
                // Hide upload zone and show canvas with new classes
                document.getElementById('uploadZone').style.display = 'none';
                document.getElementById('mainCanvas').classList.remove('hidden');
                
                resizeCanvas();
                fitToScreen();
                lines = [];
                updateStrokeCount();
                console.log('✅ Image loaded:', img.width, 'x', img.height);
                
                // Set default tool to Select after image loads
                selectTool('select');
            };
            img.crossOrigin = 'anonymous';
            img.src = src;
        }

        function drawScene() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            if (isLoading) {
                drawLoadingSkeleton();
                return;
            }
            canvasObjects.forEach(obj => drawCanvasObject(obj));
            canvasObjects.forEach(obj => {
                const objectLines = lines.filter(line => !line.objectId || line.objectId === obj.id);
                if (objectLines.length > 0) drawBrushStrokes(obj);
            });
            if (selectedObject) drawSelectionHighlight(selectedObject);
        }

        function drawCanvasObject(obj) {
            ctx.save();
            // Translate to screen position (canvas coordinates to screen)
            ctx.translate(panX + obj.x * scale, panY + obj.y * scale);
            ctx.scale(scale, scale);
            ctx.drawImage(obj.image, 0, 0);
            if (obj.label) {
                const labelColor = obj === selectedObject ? '#4CAF50' : 'rgba(0, 0, 0, 0.7)';
                ctx.fillStyle = labelColor;
                const labelWidth = ctx.measureText(obj.label).width + 10;
                ctx.fillRect(0, -25, labelWidth, 20);
                ctx.fillStyle = 'white';
                ctx.font = obj === selectedObject ? 'bold 12px system-ui' : '12px system-ui';
                ctx.fillText(obj.label, 5, -10);
                if (obj === selectedObject) {
                    ctx.fillStyle = '#4CAF50';
                    ctx.fillRect(labelWidth + 5, -20, 15, 10);
                    ctx.fillStyle = 'white';
                    ctx.font = '8px system-ui';
                    ctx.fillText('✏️', labelWidth + 7, -12);
                }
            }
            ctx.restore();
        }

        function drawBrushStrokes(imageObj) {
            // Brush strokes are stored in image-relative coordinates
            // So we just need to translate to the image's current position
            ctx.save();
            ctx.translate(panX + imageObj.x * scale, panY + imageObj.y * scale);
            ctx.scale(scale, scale);
            ctx.strokeStyle = 'rgba(76, 175, 80, 0.7)';
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            lines.forEach(line => {
                if (line.points.length > 1 && (!line.objectId || line.objectId === imageObj.id)) {
                    ctx.lineWidth = line.brushSize;
                    ctx.globalAlpha = line.brushOpacity || 1.0;
                    ctx.beginPath();
                    ctx.moveTo(line.points[0], line.points[1]);
                    for (let i = 2; i < line.points.length; i += 2) {
                        ctx.lineTo(line.points[i], line.points[i + 1]);
                    }
                    ctx.stroke();
                }
            });
            ctx.restore();
        }

        function drawSelectionHighlight(obj) {
            ctx.save();
            // Draw selection box around the object
            ctx.translate(panX + obj.x * scale - 2, panY + obj.y * scale - 2);
            ctx.scale(scale, scale);
            ctx.strokeStyle = '#2196F3';
            ctx.lineWidth = 3 / scale;
            ctx.setLineDash([5 / scale, 5 / scale]);
            ctx.strokeRect(0, 0, obj.image.width + 4 / scale, obj.image.height + 4 / scale);
            ctx.restore();
            updateObjectToolbar(obj);
        }

        function updateObjectToolbar(obj) {
            const toolbar = document.getElementById('objectToolbar');
            if (!toolbar) return;
            if (obj) {
                // Calculate screen position properly
                const screenX = panX + obj.x * scale;
                const screenY = panY + obj.y * scale;
                const toolbarX = Math.max(10, Math.min(canvas.width - 200, screenX));
                const toolbarY = Math.max(10, screenY - 50);
                toolbar.style.left = toolbarX + 'px';
                toolbar.style.top = toolbarY + 'px';
                toolbar.style.display = 'flex';
            } else {
                toolbar.style.display = 'none';
            }
        }

        function drawLoadingSkeleton() {
            const time = Date.now() * 0.002;
            const shimmer = (Math.sin(time) + 1) * 0.5;
            if (canvasObjects.length > 0) {
                const mainObj = canvasObjects.find(obj => obj.isMainImage);
                if (mainObj) {
                    ctx.save();
                    ctx.translate(panX + mainObj.x * scale, panY + mainObj.y * scale);
                    ctx.scale(scale, scale);
                    ctx.drawImage(mainObj.image, 0, 0);
                    ctx.fillStyle = `rgba(240, 240, 240, ${0.3 + shimmer * 0.3})`;
                    ctx.fillRect(0, 0, mainObj.image.width, mainObj.image.height);
                    ctx.restore();
                }
            }
            if (canvasObjects.length > 0) {
                const mainObj = canvasObjects.find(obj => obj.isMainImage);
                if (mainObj) {
                    const skeletonX = mainObj.x + mainObj.image.width + 20;
                    const skeletonY = mainObj.y;
                    ctx.save();
                    ctx.translate(panX + skeletonX * scale, panY + skeletonY * scale);
                    ctx.scale(scale, scale);
                    ctx.fillStyle = `rgba(230, 230, 230, ${0.5 + shimmer * 0.3})`;
                    ctx.fillRect(0, 0, mainObj.image.width, mainObj.image.height);
                    for (let i = 0; i < 5; i++) {
                        ctx.fillStyle = `rgba(200, 200, 200, ${0.4 + shimmer * 0.4})`;
                        ctx.fillRect(20, 20 + i * 40, mainObj.image.width - 40, 20);
                    }
                    ctx.fillStyle = '#666';
                    ctx.font = 'bold 16px system-ui';
                    ctx.textAlign = 'center';
                    ctx.fillText('🤖 Generating...', mainObj.image.width / 2, mainObj.image.height / 2);
                    ctx.restore();
                }
            }
            requestAnimationFrame(drawScene);
        }

        function handleWheel(e) {
            e.preventDefault();
            const rect = canvas.getBoundingClientRect();
            const mouseX = e.clientX - rect.left;
            const mouseY = e.clientY - rect.top;
            const scaleBy = 1.1;
            const direction = e.deltaY > 0 ? -1 : 1;
            const oldScale = scale;
            const newScale = direction > 0 ? oldScale * scaleBy : oldScale / scaleBy;
            scale = Math.max(0.1, Math.min(10, newScale));
            const scaleChange = scale / oldScale;
            panX = mouseX - (mouseX - panX) * scaleChange;
            panY = mouseY - (mouseY - panY) * scaleChange;
            drawScene();
            updateZoomDisplay();
        }

        function handleTouchStart(e) {
            e.preventDefault();
            const touch = e.touches[0];
            const mouseEvent = new MouseEvent('mousedown', { clientX: touch.clientX, clientY: touch.clientY, button: 0 });
            handleMouseDown(mouseEvent);
        }
        function handleTouchMove(e) {
            e.preventDefault();
            const touch = e.touches[0];
            const mouseEvent = new MouseEvent('mousemove', { clientX: touch.clientX, clientY: touch.clientY });
            handleMouseMove(mouseEvent);
        }
        function handleTouchEnd(e) {
            e.preventDefault();
            handleMouseUp();
        }

        function startNewLine(x, y) {
            lines.push({
                id: Date.now() + Math.random(),
                points: [x, y],
                brushSize: brushSize,
                brushOpacity: brushOpacity,
                tool: 'brush',
                objectId: selectedObject ? selectedObject.id : null
            });
        }
        function addPointToCurrentLine(x, y) {
            if (lines.length === 0) return;
            lines[lines.length - 1].points.push(x, y);
        }

        function zoomIn() { scale = Math.min(10, scale * 1.2); drawScene(); updateZoomDisplay(); }
        function zoomOut() { scale = Math.max(0.1, scale / 1.2); drawScene(); updateZoomDisplay(); }
        function resetZoom() { scale = 1; drawScene(); updateZoomDisplay(); }
        function resetView() { if (image) fitToScreen(); }
        function fitToScreen() {
            if (canvasObjects.length === 0) return;
            let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
            canvasObjects.forEach(obj => {
                minX = Math.min(minX, obj.x);
                minY = Math.min(minY, obj.y);
                maxX = Math.max(maxX, obj.x + obj.image.width);
                maxY = Math.max(maxY, obj.y + obj.image.height);
            });
            const totalWidth = maxX - minX;
            const totalHeight = maxY - minY;
            const containerWidth = canvas.width - 100;
            const containerHeight = canvas.height - 100;
            const scaleX = containerWidth / totalWidth;
            const scaleY = containerHeight / totalHeight;
            scale = Math.min(scaleX, scaleY, 1);
            panX = (canvas.width - totalWidth * scale) / 2 - minX * scale;
            panY = (canvas.height - totalHeight * scale) / 2 - minY * scale;
            drawScene();
            updateZoomDisplay();
        }
        function updateZoomDisplay() {
            const percent = Math.round(scale * 100);
            const zoomInfo = document.getElementById('zoomInfo');
            const headerZoom = document.getElementById('headerZoomDisplay');
            
            if (zoomInfo) {
                zoomInfo.textContent = `Zoom: ${percent}%`;
            }
            if (headerZoom) {
                headerZoom.textContent = `${percent}%`;
            }
        }
        function updateStrokeCount() {
            const count = lines.length;
            const strokeCountEl = document.getElementById('strokeCount');
            if (strokeCountEl) {
                strokeCountEl.textContent = count;
            }
        }

        async function resetDrawing() {
            if (lines.length > 0) {
                const confirmed = await showCustomConfirm(
                    'Clear All Brush Strokes?',
                    'This action cannot be undone. All brush strokes will be permanently removed.'
                );
                
                if (confirmed) {
                    saveState();
                    lines = [];
                    updateStrokeCount();
                    // Force a complete redraw
                    ctx.clearRect(0, 0, canvas.width, canvas.height);
                    drawScene();
                }
            }
        }

        function downloadMask() {
            if (!selectedObject) { 
                showCustomAlert('No Selection', 'Please select an image first.', 'warning'); 
                return; 
            }
            const objectLines = lines.filter(line => line.objectId === selectedObject.id);
            if (objectLines.length === 0) {
                showCustomAlert('No Brush Strokes', 'Please draw some brush strokes on the selected image to create a mask.', 'warning');
                return;
            }

            try {
                const maskCanvas = createMaskCanvas(selectedObject.id);
                const maskDataUrl = maskCanvas.toDataURL('image/png');
                
                // Create download link
                const link = document.createElement('a');
                link.href = maskDataUrl;
                link.download = `mask-${Date.now()}.png`;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                
                console.log('✅ Mask downloaded successfully');
            } catch (error) {
                console.error('❌ Error downloading mask:', error);
                showCustomAlert('Download Failed', 'Failed to download mask. Please try again.', 'error');
            }
        }

        async function handleErase() {
            if (!selectedObject) { 
                showCustomAlert('No Selection', 'Please select an image first.', 'warning'); 
                return; 
            }
            const objectLines = lines.filter(line => line.objectId === selectedObject.id);
            if (objectLines.length === 0) {
                showCustomAlert('No Brush Strokes', 'Please draw some brush strokes on the selected image to define the area to erase.', 'warning');
                return;
            }
            const eraseBtn = Array.from(document.querySelectorAll('.floating-btn')).find(btn => btn.textContent.includes('Erase'));
            let originalText = eraseBtn ? eraseBtn.textContent : '🗑️ Erase';
            try {
                isLoading = true;
                drawScene();
                if (eraseBtn) {
                    eraseBtn.textContent = '⏳ Erasing...';
                    eraseBtn.disabled = true;
                    eraseBtn.style.background = '#ff9800';
                }
                const maskCanvas = createMaskCanvas(selectedObject.id);
                const maskDataUrl = maskCanvas.toDataURL('image/png'); // PNG preserves exact mask data
                console.log('🎭 Mask created:', maskCanvas.width, 'x', maskCanvas.height, 'Brush strokes:', objectLines.length);
                console.log('🎭 Mask data URL length:', maskDataUrl.length, 'characters');
                
                const originalCanvas = document.createElement('canvas');
                originalCanvas.width = selectedObject.image.width;
                originalCanvas.height = selectedObject.image.height;
                const originalCtx = originalCanvas.getContext('2d');
                originalCtx.drawImage(selectedObject.image, 0, 0);
                const originalDataUrl = originalCanvas.toDataURL('image/png');
                console.log('🖼️ Original image:', originalCanvas.width, 'x', originalCanvas.height);
                
                const response = await fetch('http://localhost:3000/api/generate-with-mask', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        originalImage: originalDataUrl,
                        mask: maskDataUrl,
                        prompt: 'Remove the content in the masked area and fill it with appropriate background that matches the surrounding area seamlessly. Make it look natural as if the content was never there.',
                        brushStrokes: objectLines.length,
                        imageSize: { width: selectedObject.image.width, height: selectedObject.image.height }
                    })
                });
                if (!response.ok) throw new Error(`Erase failed: ${response.status}`);
                const result = await response.json();
                if (result.success && result.generatedImage) {
                    await displayGeneratedResult(result.generatedImage);
                    console.log('✅ Content erased successfully');
                } else {
                    throw new Error(result.error || 'Erase failed');
                }
            } catch (error) {
                console.error('❌ Erase error:', error);
                showCustomAlert('Erase Failed', `Erase failed: ${error.message}`, 'error');
            } finally {
                isLoading = false;
                if (eraseBtn) {
                    eraseBtn.textContent = originalText;
                    eraseBtn.disabled = false;
                    eraseBtn.style.background = '#4CAF50';
                }
                drawScene();
            }
        }

        async function handleReplaceText() {
            if (!selectedObject) { 
                showCustomAlert('No Selection', 'Please select an image first.', 'warning'); 
                return; 
            }
            const objectLines = lines.filter(line => line.objectId === selectedObject.id);
            if (objectLines.length === 0) {
                showCustomAlert('No Brush Strokes', 'Please draw some brush strokes on the selected image to define the area for text replacement.', 'warning');
                return;
            }
            const textToReplace = await showCustomPrompt(
                'Text Replacement',
                'Enter the text you want to place in the masked area:',
                'Your text here...',
                'Your text here'
            );
            if (!textToReplace || textToReplace.trim() === '') return;
            const replaceBtn = Array.from(document.querySelectorAll('.floating-btn')).find(btn => btn.textContent.includes('Replace'));
            let originalText = replaceBtn ? replaceBtn.textContent : '📝 Replace Text';
            try {
                isLoading = true;
                drawScene();
                if (replaceBtn) {
                    replaceBtn.textContent = '⏳ Replacing...';
                    replaceBtn.disabled = true;
                    replaceBtn.style.background = '#ff9800';
                }
                const maskCanvas = createMaskCanvas(selectedObject.id);
                const maskDataUrl = maskCanvas.toDataURL('image/png'); // PNG preserves exact mask data
                const originalCanvas = document.createElement('canvas');
                originalCanvas.width = selectedObject.image.width;
                originalCanvas.height = selectedObject.image.height;
                const originalCtx = originalCanvas.getContext('2d');
                originalCtx.drawImage(selectedObject.image, 0, 0);
                const originalDataUrl = originalCanvas.toDataURL('image/png');
                const response = await fetch('http://localhost:3000/api/generate-with-mask', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        originalImage: originalDataUrl,
                        mask: maskDataUrl,
                        prompt: `Replace the content in the masked area with the text "${textToReplace}". Make the text look natural and well-integrated into the image. Match the style, lighting, and perspective of the surrounding area. Use appropriate typography that fits the image context.`,
                        brushStrokes: objectLines.length,
                        imageSize: { width: selectedObject.image.width, height: selectedObject.image.height }
                    })
                });
                if (!response.ok) throw new Error(`Text replacement failed: ${response.status}`);
                const result = await response.json();
                if (result.success && result.generatedImage) {
                    await displayGeneratedResult(result.generatedImage);
                    console.log('✅ Text replacement completed successfully');
                } else {
                    throw new Error(result.error || 'Text replacement failed');
                }
            } catch (error) {
                console.error('❌ Text replacement error:', error);
                showCustomAlert('Text Replacement Failed', `Text replacement failed: ${error.message}`, 'error');
            } finally {
                isLoading = false;
                if (replaceBtn) {
                    replaceBtn.textContent = originalText;
                    replaceBtn.disabled = false;
                    replaceBtn.style.background = '#4CAF50';
                }
                drawScene();
            }
        }

        async function handleGenerate() {
            if (!selectedObject) { 
                showCustomAlert('No Selection', 'Please select an image first.', 'warning'); 
                return; 
            }
            const objectLines = lines.filter(line => line.objectId === selectedObject.id);
            if (objectLines.length === 0) {
                showCustomAlert('No Brush Strokes', 'Please draw some brush strokes on the selected image to define the area for generation.', 'warning');
                return;
            }
            const defaultPrompt = 'Fill the masked area with appropriate content that matches the surrounding image style and lighting';
            const prompt = await showCustomPrompt(
                'AI Generation Prompt',
                'Describe what you want to generate in the masked area:',
                'Fill the masked area with appropriate content that matches the style...',
                defaultPrompt
            );
            if (!prompt || prompt.trim() === '') return;
            const generateBtn = Array.from(document.querySelectorAll('.floating-btn')).find(btn => btn.textContent.includes('Generate'));
            let originalText = generateBtn ? generateBtn.textContent : '🤖 Generate';
            try {
                isLoading = true;
                drawScene();
                if (generateBtn) {
                    generateBtn.textContent = '⏳ Generating...';
                    generateBtn.disabled = true;
                    generateBtn.style.background = '#ff9800';
                }
                const maskCanvas = createMaskCanvas(selectedObject.id);
                const maskDataUrl = maskCanvas.toDataURL('image/png'); // PNG preserves exact mask data
                const originalCanvas = document.createElement('canvas');
                originalCanvas.width = selectedObject.image.width;
                originalCanvas.height = selectedObject.image.height;
                const originalCtx = originalCanvas.getContext('2d');
                originalCtx.drawImage(selectedObject.image, 0, 0);
                const originalDataUrl = originalCanvas.toDataURL('image/png');
                const response = await fetch('http://localhost:3000/api/generate-with-mask', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        originalImage: originalDataUrl,
                        mask: maskDataUrl,
                        prompt: prompt,
                        brushStrokes: objectLines.length,
                        imageSize: { width: selectedObject.image.width, height: selectedObject.image.height }
                    })
                });
                if (!response.ok) throw new Error(`Generation failed: ${response.status}`);
                const result = await response.json();
                if (result.success && result.generatedImage) {
                    await displayGeneratedResult(result.generatedImage);
                    console.log('✅ Generation completed successfully');
                } else {
                    throw new Error(result.error || 'Generation failed');
                }
            } catch (error) {
                console.error('❌ Generation error:', error);
                showCustomAlert('Generation Failed', `Generation failed: ${error.message}`, 'error');
            } finally {
                isLoading = false;
                if (generateBtn) {
                    generateBtn.textContent = originalText;
                    generateBtn.disabled = false;
                    generateBtn.style.background = '#4CAF50';
                }
                drawScene();
            }
        }

        function createMaskCanvas(objectId = null) {
            const targetObject = objectId ? canvasObjects.find(obj => obj.id === objectId) || selectedObject : selectedObject;
            if (!targetObject) {
                showCustomAlert('No Target Object', 'No target object found for mask creation.', 'error');
                return null;
            }
            const maskCanvas = document.createElement('canvas');
            maskCanvas.width = targetObject.image.width;
            maskCanvas.height = targetObject.image.height;
            const maskCtx = maskCanvas.getContext('2d');
            maskCtx.fillStyle = 'black';
            maskCtx.fillRect(0, 0, maskCanvas.width, maskCanvas.height);
            maskCtx.strokeStyle = 'white';
            maskCtx.lineCap = 'round';
            maskCtx.lineJoin = 'round';
            const relevantLines = lines.filter(line => !line.objectId || line.objectId === targetObject.id);
            relevantLines.forEach(line => {
                if (line.points.length > 1) {
                    maskCtx.lineWidth = line.brushSize;
                    maskCtx.beginPath();
                    maskCtx.moveTo(line.points[0], line.points[1]);
                    for (let i = 2; i < line.points.length; i += 2) {
                        maskCtx.lineTo(line.points[i], line.points[i + 1]);
                    }
                    maskCtx.stroke();
                }
            });
            return maskCanvas;
        }

        function createMaskImage() {
            if (!selectedObject) { 
                showCustomAlert('No Selection', 'Please select an image first.', 'warning'); 
                return; 
            }
            const objectLines = lines.filter(line => line.objectId === selectedObject.id);
            if (objectLines.length === 0) {
                showCustomAlert('No Brush Strokes', 'No brush strokes on selected image to create a mask.', 'warning');
                return;
            }
            const maskCanvas = createMaskCanvas(selectedObject.id);
            if (!maskCanvas) return;
            const link = document.createElement('a');
            link.download = `mask-${selectedObject.label || selectedObject.id}.png`;
            link.href = maskCanvas.toDataURL();
            link.click();
            console.log('Mask created with dimensions:', selectedObject.image.width, 'x', selectedObject.image.height);
        }

        function downloadImage() {
            if (canvasObjects.length === 0) {
                showCustomAlert('No Images', 'No images to download.', 'warning');
                return;
            }
            const mainImage = canvasObjects.find(obj => obj.isMainImage);
            if (!mainImage) {
                showCustomAlert('No Main Image', 'No main image found.', 'warning');
                return;
            }
            const exportCanvas = document.createElement('canvas');
            exportCanvas.width = mainImage.image.width;
            exportCanvas.height = mainImage.image.height;
            const exportCtx = exportCanvas.getContext('2d');
            exportCtx.drawImage(mainImage.image, 0, 0);
            exportCtx.strokeStyle = 'rgba(76, 175, 80, 0.7)';
            exportCtx.lineCap = 'round';
            exportCtx.lineJoin = 'round';
            lines.forEach(line => {
                if (line.points.length > 1) {
                    exportCtx.lineWidth = line.brushSize;
                    exportCtx.beginPath();
                    exportCtx.moveTo(line.points[0], line.points[1]);
                    for (let i = 2; i < line.points.length; i += 2) {
                        exportCtx.lineTo(line.points[i], line.points[i + 1]);
                    }
                    exportCtx.stroke();
                }
            });
            const link = document.createElement('a');
            link.download = 'edited-image.png';
            link.href = exportCanvas.toDataURL();
            link.click();
        }

        function downloadSelectedImage() {
            if (!selectedObject) {
                showCustomAlert('No Selection', 'No image selected.', 'warning');
                return;
            }
            const exportCanvas = document.createElement('canvas');
            exportCanvas.width = selectedObject.image.width;
            exportCanvas.height = selectedObject.image.height;
            const exportCtx = exportCanvas.getContext('2d');
            exportCtx.drawImage(selectedObject.image, 0, 0);
            const link = document.createElement('a');
            link.download = `${selectedObject.label || 'image'}-${Date.now()}.png`;
            link.href = exportCanvas.toDataURL();
            link.click();
            showTemporaryMessage('💾 Download started', '#4CAF50');
        }

        function saveState() {
            const stateCopy = JSON.parse(JSON.stringify(lines));
            undoStack.push(stateCopy);
            console.log('State saved. Undo stack size:', undoStack.length, 'Lines count:', lines.length);
            if (undoStack.length > 50) undoStack.shift();
            redoStack = [];
        }
        function undo() {
            console.log('=== UNDO CALLED ===');
            console.log('Current undo stack size:', undoStack.length);
            console.log('Current lines count:', lines.length);
            
            if (undoStack.length > 0) {
                console.log('Undo: Moving current state to redo stack');
                redoStack.push(JSON.parse(JSON.stringify(lines)));
                lines = undoStack.pop();
                console.log('Undo: Restored state. New lines count:', lines.length);
                updateStrokeCount();
                drawScene();
            } else {
                console.log('Undo: No history available');
            }
        }
        function redo() {
            console.log('=== REDO CALLED ===');
            console.log('Current redo stack size:', redoStack.length);
            
            if (redoStack.length > 0) {
                console.log('Redo: Moving current state to undo stack');
                undoStack.push(JSON.parse(JSON.stringify(lines)));
                lines = redoStack.pop();
                console.log('Redo: Restored state. New lines count:', lines.length);
                updateStrokeCount();
                drawScene();
            } else {
                console.log('Redo: No redo history available');
            }
        }

        function deleteSelectedObject() {
            if (selectedObject && !selectedObject.isMainImage) {
                const index = canvasObjects.indexOf(selectedObject);
                if (index > -1) {
                    canvasObjects.splice(index, 1);
                    selectedObject = canvasObjects.find(obj => obj.isMainImage) || null;
                    updateObjectToolbar(selectedObject);
                    drawScene();
                    showTemporaryMessage('🗑️ Image deleted', '#FF5722');
                }
            }
        }
        function duplicateSelectedObject() {
            if (selectedObject) {
                const newObj = {
                    id: 'copy-' + Date.now(),
                    image: selectedObject.image,
                    x: selectedObject.x + 20,
                    y: selectedObject.y + 20,
                    isMainImage: false,
                    label: selectedObject.label + ' (Copy)'
                };
                canvasObjects.push(newObj);
                selectedObject = newObj;
                drawScene();
                showTemporaryMessage('📋 Image duplicated', '#2196F3');
            }
        }
        function bringToFront() {
            if (selectedObject) {
                const index = canvasObjects.indexOf(selectedObject);
                if (index > -1) {
                    canvasObjects.splice(index, 1);
                    canvasObjects.push(selectedObject);
                    drawScene();
                }
            }
        }
        function sendToBack() {
            if (selectedObject && !selectedObject.isMainImage) {
                const index = canvasObjects.indexOf(selectedObject);
                if (index > -1) {
                    canvasObjects.splice(index, 1);
                    canvasObjects.splice(1, 0, selectedObject);
                    drawScene();
                }
            }
        }

        function showTemporaryMessage(message, color) {
            const messageDiv = document.createElement('div');
            messageDiv.style.cssText = `
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                background: ${color};
                color: white;
                padding: 15px 25px;
                border-radius: 8px;
                font-weight: 600;
                box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
                z-index: 1000;
                animation: fadeInOut 2s ease-in-out forwards;
            `;
            messageDiv.textContent = message;
            document.querySelector('.canvas-container').appendChild(messageDiv);
            if (!document.querySelector('#tempMessageStyles')) {
                const style = document.createElement('style');
                style.id = 'tempMessageStyles';
                style.textContent = `
                    @keyframes fadeInOut {
                        0% { opacity: 0; transform: translate(-50%, -50%) scale(0.8); }
                        20% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
                        80% { opacity: 1; transform: translate(-50%, -50%) scale(1); }
                        100% { opacity: 0; transform: translate(-50%, -50%) scale(0.8); }
                    }
                `;
                document.head.appendChild(style);
            }
            setTimeout(() => {
                if (messageDiv.parentNode) messageDiv.parentNode.removeChild(messageDiv);
            }, 2000);
        }

        function applyChanges() { 
            // Placeholder function - you'll provide details later
            showCustomAlert('Coming Soon', 'Apply changes functionality will be implemented soon.', 'info'); 
        }
        
        function showHelp() {
            const helpMessage = `<strong>Tools:</strong><br>
                • V: Select tool<br>
                • R: Retouch tool<br>
                • B: Background tool<br>
                • E: Expand tool<br>
                • U: Upscale tool<br><br>
                <strong>Editing:</strong><br>
                • Ctrl+Z: Undo<br>
                • Ctrl+Shift+Z: Redo<br>
                • Delete: Delete selected object<br>
                • Ctrl+D: Duplicate object<br><br>
                <strong>Navigation:</strong><br>
                • Space + Drag: Pan canvas<br>
                • Mouse Wheel: Zoom<br>
                • Ctrl+0: Reset view<br><br>
                <strong>Layer Management:</strong><br>
                • Ctrl+Shift+]: Bring to front<br>
                • Ctrl+Shift+[: Send to back`;
            
            showCustomAlert('Keyboard Shortcuts', helpMessage, 'info');
        }
        function closeEditor() {
            if (window.opener) window.close();
            else if (document.referrer) history.back();
            else window.location.href = '/';
        }

        // Custom Prompt Modal
        let promptModalResolve = null;

        function showCustomPrompt(title, description, placeholder, defaultValue = '') {
            return new Promise((resolve) => {
                promptModalResolve = resolve;
                
                // Create modal HTML
                const modalHTML = `
                    <div class="prompt-modal-overlay" id="promptModalOverlay" onclick="if(event.target === this) closeCustomPrompt(null)">
                        <div class="prompt-modal-container">
                            <div class="prompt-modal-header">
                                <div class="prompt-modal-title-row">
                                    <div class="prompt-modal-icon">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                                        </svg>
                                    </div>
                                    <h3 class="prompt-modal-title">${title}</h3>
                                </div>
                                <p class="prompt-modal-description">${description}</p>
                            </div>
                            <div class="prompt-modal-body">
                                <textarea 
                                    class="prompt-modal-textarea" 
                                    id="promptModalTextarea"
                                    placeholder="${placeholder}"
                                    autofocus
                                >${defaultValue}</textarea>
                            </div>
                            <div class="prompt-modal-footer">
                                <button class="prompt-modal-btn prompt-modal-btn-cancel" onclick="closeCustomPrompt(null)">
                                    Cancel
                                </button>
                                <button class="prompt-modal-btn prompt-modal-btn-primary" onclick="submitCustomPrompt()">
                                    Generate
                                </button>
                            </div>
                        </div>
                    </div>
                `;
                
                // Add to body
                document.body.insertAdjacentHTML('beforeend', modalHTML);
                
                // Focus textarea after a brief delay
                setTimeout(() => {
                    const textarea = document.getElementById('promptModalTextarea');
                    if (textarea) {
                        textarea.focus();
                        textarea.select();
                    }
                }, 100);
                
                // Add Enter key listener (Ctrl+Enter to submit)
                document.getElementById('promptModalTextarea').addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' && e.ctrlKey) {
                        e.preventDefault();
                        submitCustomPrompt();
                    } else if (e.key === 'Escape') {
                        e.preventDefault();
                        closeCustomPrompt(null);
                    }
                });
            });
        }

        function submitCustomPrompt() {
            const textarea = document.getElementById('promptModalTextarea');
            const value = textarea ? textarea.value.trim() : '';
            closeCustomPrompt(value || null);
        }

        function closeCustomPrompt(value) {
            const overlay = document.getElementById('promptModalOverlay');
            if (overlay) {
                overlay.style.animation = 'fadeOut 0.2s ease forwards';
                setTimeout(() => {
                    overlay.remove();
                    if (promptModalResolve) {
                        promptModalResolve(value);
                        promptModalResolve = null;
                    }
                }, 200);
            }
        }

        // Custom Confirmation Modal
        let confirmModalResolve = null;

        function showCustomConfirm(title, message) {
            return new Promise((resolve) => {
                confirmModalResolve = resolve;
                
                // Create modal HTML
                const modalHTML = `
                    <div class="prompt-modal-overlay" id="confirmModalOverlay" onclick="if(event.target === this) closeCustomConfirm(false)">
                        <div class="prompt-modal-container">
                            <div class="prompt-modal-header">
                                <div class="prompt-modal-title-row">
                                    <div class="prompt-modal-icon">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                                            <line x1="12" y1="9" x2="12" y2="13"/>
                                            <line x1="12" y1="17" x2="12.01" y2="17"/>
                                        </svg>
                                    </div>
                                    <h3 class="prompt-modal-title">${title}</h3>
                                </div>
                                <p class="prompt-modal-description">${message}</p>
                            </div>
                            <div class="prompt-modal-footer">
                                <button class="prompt-modal-btn prompt-modal-btn-cancel" onclick="closeCustomConfirm(false)">
                                    Cancel
                                </button>
                                <button class="prompt-modal-btn prompt-modal-btn-danger" onclick="closeCustomConfirm(true)">
                                    Clear All
                                </button>
                            </div>
                        </div>
                    </div>
                `;
                
                // Add to body
                document.body.insertAdjacentHTML('beforeend', modalHTML);
                
                // Add Escape key listener
                const overlay = document.getElementById('confirmModalOverlay');
                overlay.addEventListener('keydown', (e) => {
                    if (e.key === 'Escape') {
                        e.preventDefault();
                        closeCustomConfirm(false);
                    }
                });
            });
        }

        function closeCustomConfirm(value) {
            const overlay = document.getElementById('confirmModalOverlay');
            if (overlay) {
                overlay.style.animation = 'fadeOut 0.2s ease forwards';
                setTimeout(() => {
                    overlay.remove();
                    if (confirmModalResolve) {
                        confirmModalResolve(value);
                        confirmModalResolve = null;
                    }
                }, 200);
            }
        }

        // Custom Alert Modal
        let alertModalResolve = null;

        function showCustomAlert(title, message, type = 'info') {
            return new Promise((resolve) => {
                alertModalResolve = resolve;
                
                // Choose icon based on type
                let iconSVG = '';
                if (type === 'error') {
                    iconSVG = `
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="15" y1="9" x2="9" y2="15"/>
                            <line x1="9" y1="9" x2="15" y2="15"/>
                        </svg>
                    `;
                } else if (type === 'warning') {
                    iconSVG = `
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                            <line x1="12" y1="9" x2="12" y2="13"/>
                            <line x1="12" y1="17" x2="12.01" y2="17"/>
                        </svg>
                    `;
                } else {
                    iconSVG = `
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <line x1="12" y1="8" x2="12" y2="12"/>
                            <line x1="12" y1="16" x2="12.01" y2="16"/>
                        </svg>
                    `;
                }
                
                // Create modal HTML
                const modalHTML = `
                    <div class="prompt-modal-overlay" id="alertModalOverlay" onclick="if(event.target === this) closeCustomAlert()">
                        <div class="prompt-modal-container">
                            <div class="prompt-modal-header">
                                <div class="prompt-modal-title-row">
                                    <div class="prompt-modal-icon">
                                        ${iconSVG}
                                    </div>
                                    <h3 class="prompt-modal-title">${title}</h3>
                                </div>
                                <p class="prompt-modal-description">${message}</p>
                            </div>
                            <div class="prompt-modal-footer">
                                <button class="prompt-modal-btn prompt-modal-btn-primary" onclick="closeCustomAlert()" autofocus>
                                    OK
                                </button>
                            </div>
                        </div>
                    </div>
                `;
                
                // Add to body
                document.body.insertAdjacentHTML('beforeend', modalHTML);
                
                // Add Enter key listener
                const overlay = document.getElementById('alertModalOverlay');
                overlay.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter' || e.key === 'Escape') {
                        e.preventDefault();
                        closeCustomAlert();
                    }
                });
                
                // Focus the OK button
                setTimeout(() => {
                    const okButton = overlay.querySelector('.prompt-modal-btn-primary');
                    if (okButton) okButton.focus();
                }, 100);
            });
        }

        function closeCustomAlert() {
            const overlay = document.getElementById('alertModalOverlay');
            if (overlay) {
                overlay.style.animation = 'fadeOut 0.2s ease forwards';
                setTimeout(() => {
                    overlay.remove();
                    if (alertModalResolve) {
                        alertModalResolve();
                        alertModalResolve = null;
                    }
                }, 200);
            }
        }

        // Add fadeOut animation
        const style = document.createElement('style');
        style.textContent = `
            @keyframes fadeOut {
                to {
                    opacity: 0;
                }
            }
        `;
        document.head.appendChild(style);
    </script>
</body>
</html>