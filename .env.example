# ─────────────────────────────────────────────────────────────────────────────
# SnapDraft — Environment Configuration
# Copy this file to .env and fill in all required values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=SnapDraft
APP_ENV=production          # local | staging | production
APP_KEY=                    # Generate with: php artisan key:generate
APP_DEBUG=false
APP_URL=https://yourdomain.com

# Optional: X profile URL for homepage Support (new tab), e.g. https://x.com/yourhandle
SUPPORT_X_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error             # debug | info | warning | error

# ── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=snapdraft
DB_USERNAME=snapdraft
DB_PASSWORD=

# ── Queue & Cache ─────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public      # Use 's3' in production
QUEUE_CONNECTION=database   # Use 'redis' in production
CACHE_STORE=database        # Use 'redis' in production
CACHE_PREFIX=snapdraft_

# ── Redis (recommended for production) ───────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ─────────────────────────────────────────────────────────────────────
# Recommended: Postmark or Resend for production
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"

# ── File Storage (S3 or DigitalOcean Spaces for production) ──────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────────────
# AI Services — REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini (Primary AI Service) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash
GEMINI_TEXT_TO_IMAGE_MODEL=imagen-3.0-generate-001
GEMINI_RATE_LIMIT=10
GEMINI_TIMEOUT=120

# Legacy Google API Key alias (can be same as GEMINI_API_KEY)
GOOGLE_API_KEY=

# Fal.ai (AI upscale — server-side only, never expose to frontend) — https://fal.ai/dashboard/keys
FAL_API_KEY=

# OpenRouter (CSV wizard pipeline — DNA, post JSON, image gen) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME="${APP_NAME}"
OPENROUTER_SITE_URL="${APP_URL}"
OPENROUTER_MODEL=openai/gpt-4o
AI_DEFAULT_ANALYZER=gpt-4o
AI_DEFAULT_POST_MODEL=gpt-4o
AI_DEFAULT_GENERATOR=nano-banana-2
AI_ANALYZE_TIMEOUT=300

# ─────────────────────────────────────────────────────────────────────────────
# Payments — REQUIRED for subscriptions
# ─────────────────────────────────────────────────────────────────────────────

# Lemon Squeezy — https://app.lemonsqueezy.com
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_TEST_MODE=false
LEMON_SQUEEZY_VERIFY_SSL=true   # Set to false ONLY on local XAMPP dev (cacert issue)

# Lemon Squeezy variant IDs — create product + variants in your LS dashboard
LEMON_SQUEEZY_BETA_MONTHLY_VARIANT_ID=
LEMON_SQUEEZY_BETA_YEARLY_VARIANT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth — REQUIRED for social login
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {APP_URL}/auth/google/callback
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=/auth/google/callback

# ─────────────────────────────────────────────────────────────────────────────
# Monitoring (optional but recommended for production)
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog — project token from https://us.posthog.com/project/settings (same key for PHP + posthog-js)
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_DISABLED=false
# Client-only: avoids session recorder / dead-click assets (strict CSP or privacy)
POSTHOG_DISABLE_SESSION_RECORDING=false
POSTHOG_CAPTURE_DEAD_CLICKS=true

# Beta applications — email that receives NewBetaApplicationNotification when someone applies
BETA_APPLICATION_NOTIFY_EMAIL=
